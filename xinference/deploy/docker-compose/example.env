# Copy this file to .env before starting the stack.
# Example environment configuration for Xinference Docker Compose.

# Xinference image tag to use.
VERSION=v2.9.0

# Model source for Xinference.
XINFERENCE_MODEL_SRC=modelscope

# Host base directory used for Xinference cache and model data.
# Use your real home directory on the host machine, for example:
# HOST_XINFERENCE_BASE=/home/your-user
HOST_XINFERENCE_BASE=$HOME
